{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "match_report",
  "type": "object",
  "required": [
    "schema_version",
    "artifact_type",
    "created_at",
    "run_id",
    "candidate_id",
    "job_id",
    "overall",
    "component_scores",
    "gaps"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "artifact_type": { "const": "match_report" },
    "created_at": { "type": "string" },
    "run_id": { "type": "string" },
    "candidate_id": { "type": "string" },
    "job_id": { "type": "string" },

    "overall": {
      "type": "object",
      "required": ["fit_label", "fit_score"],
      "properties": {
        "fit_label": {
          "type": "string",
          "enum": ["Strong", "Medium", "Weak"]
        },
        "fit_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "one_sentence_verdict": { "type": "string" }
      },
      "additionalProperties": false
    },

    "component_scores": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["score", "notes"],
        "properties": {
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },

    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence_chunks"],
        "properties": {
          "claim": { "type": "string" },
          "evidence_chunks": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },

    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap", "impact", "recommended_fix", "suggested_keywords"],
        "properties": {
          "gap": { "type": "string" },
          "impact": { "type": "string" },
          "recommended_fix": { "type": "string" },
          "suggested_keywords": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },

    "language_optimization": {
      "type": "object",
      "properties": {
        "add_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "replace_phrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tone_guidance": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "guardrails": {
      "type": "object",
      "properties": {
        "blocked_claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "next_actions": {
      "type": "array",
      "items": { "type": "string" }
    },

    "rubric": {
      "type": "object",
      "properties": {
        "rubric_version": { "type": "string" },
        "weights_used": {}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}